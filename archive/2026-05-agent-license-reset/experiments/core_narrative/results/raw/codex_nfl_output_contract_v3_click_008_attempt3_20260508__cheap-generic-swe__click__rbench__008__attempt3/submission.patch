+def test_option_prompt_required(runner):
+    @click.command()
+    @click.option(
+        "--name",
+        default="World",
+        prompt=True,
+        prompt_required=False,
+        required=True,
+    )
+    def cmd(name):
+        click.echo(name)
+
+    result = runner.invoke(cmd, ["--name"])
+    assert result.exit_code == 0
+    assert result.output == "World\n"
+
+    result = runner.invoke(cmd, [], input="Jane\n")
+    assert result.exit_code == 0
+    assert "Jane" in result.output
+
+
