+@pytest.mark.parametrize('default', [('foo', 'bar'), ['foo', 'bar']])
+def test_multiple_default_help(runner, default):
+    @click.command()
+    @click.option('--arg', multiple=True, default=default, show_default=True)
+    def cmd(arg):
+        pass
+
+    result = runner.invoke(cmd, ['--help'])
+    assert not result.exception
+    assert '[default: %s]' % (default,) in result.output
