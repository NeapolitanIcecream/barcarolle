+
+
+def test_pdb_streams_are_isolated_and_restored():
+    original_init = pdb.Pdb.__init__
+
+    @click.command()
+    def cli():
+        debugger = pdb.Pdb()
+        click.echo(debugger.stdin is sys.__stdin__)
+        click.echo(debugger.stdout is sys.__stdout__)
+
+        stdin = StringIO()
+        stdout = StringIO()
+        debugger = pdb.Pdb(stdin=stdin, stdout=stdout)
+        click.echo(debugger.stdin is stdin)
+        click.echo(debugger.stdout is stdout)
+
+    runner = CliRunner()
+    result = runner.invoke(cli)
+
+    assert not result.exception
+    assert result.output == "True\nTrue\nTrue\nTrue\n"
+    assert pdb.Pdb.__init__ is original_init
