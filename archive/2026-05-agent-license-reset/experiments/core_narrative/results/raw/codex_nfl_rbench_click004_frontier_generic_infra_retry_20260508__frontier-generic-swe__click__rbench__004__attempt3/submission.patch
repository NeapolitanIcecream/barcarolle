+def test_result_streams():
+    @click.command()
+    def test():
+        sys.stdout.write('1')
+        sys.stderr.write('2')
+        sys.stdout.write('3')
+
+    runner = CliRunner()
+    result = runner.invoke(test)
+    assert not result.exception
+    assert result.output == '123'
+    assert result.stdout == '13'
+    assert result.stderr == '2'
+    assert result.output_bytes == b'123'
+    assert result.stdout_bytes == b'13'
+    assert result.stderr_bytes == b'2'
+
