+def test_pdb_uses_real_stdio_and_restores():
+    old_pdb_init = pdb.Pdb.__init__
+    real_stdin = sys.stdin
+    real_stdout = sys.stdout
+    custom_stdin = StringIO()
+    custom_stdout = StringIO()
+
+    @click.command()
+    def cli():
+        debugger = pdb.Pdb(readrc=False)
+        assert debugger.stdin is real_stdin
+        assert debugger.stdout is real_stdout
+
+        debugger = pdb.Pdb(stdin=custom_stdin, stdout=custom_stdout, readrc=False)
+        assert debugger.stdin is custom_stdin
+        assert debugger.stdout is custom_stdout
+
+    runner = CliRunner()
+    result = runner.invoke(cli)
+
+    assert result.exception is None
+    assert pdb.Pdb.__init__ is old_pdb_init
+
+    debugger = pdb.Pdb(readrc=False)
+    assert debugger.stdin is sys.stdin
+    assert debugger.stdout is sys.stdout
+
