ult:\\n                    return t.cast(Option, param).flag_value\\n\\n            return None\\n\\n        return super().get_default(ctx, call=call)\\n\",\"new\":\"    def get_default(self, ctx: Context, call: bool = True) -> t.Any | None:\\n        return super().get_default(ctx, call=call)\\n\"},{\"path\":\"tests/test_options.py\",\"old\":\"def test_parse_multiple_default_composite_type(runner):\\n    @click.command()\\n    @click.option(\\\"-a\\\", multiple=True, default=(\\\"a\\\", \\\"b\\\"))\\n    @click.option(\\\"-b\\\", multiple=True, default=[(1, \\\"a\\\")])\\n    def cmd(a, b):\\n        click.echo(a)\\n        click.echo(b)\\n\\n    # result = runner.invoke(cmd, \\\"-a c -a 1 -a d -b 2 two -b 4 four\\\".split())\\n    # assert result.output == \\\"('c', '1', 'd')\\\\n((2, 'two'), (4, 'four'))\\\\n\\\"\\n    result = runner.invoke(cmd)\\n    assert result.output == \\\"('a', 'b')\\\\n((1, 'a'),)\\\\n\\\"\\n\",\"new\":\"def test_parse_multiple_default_composite_type(runner):\\n    @click.command()\\n    @click.option(\\\"-a\\\", multiple=True, default=(\\\"a\\\", \\\"b\\\"))\\n    @click.option(\\\"-b\\\", multiple=True, default=[(1, \\\"a\\\")])\\n    def cmd(a, b):\\n        click.echo(a)\\n        click.echo(b)\\n\\n    # result = runner.invoke(cmd, \\\"-a c -a 1 -a d -b 2 two -b 4 four\\\".split())\\n    # assert result.output == \\\"('c', '1', 'd')\\\\n((2, 'two'), (4, 'four'))\\\\n\\\"\\n    result = runner.invoke(cmd)\\n    assert result.output == \\\"('a', 'b')\\\\n((1, 'a'),)\\\\n\\\"\\n\\n\\n@pytest.mark.parametrize(\\n    (\\\"default\\\", \\\"flag_value\\\", \\\"type\\\", \\\"expected_default\\\", \\\"expected_flag\\\"),\\n    [\\n        (\\\"default\\\", \\\"flag\\\", None, \\\"default\\\", \\\"flag\\\"),\\n        (0, 1, None, 0, 1),\\n        (0, 1, str, \\\"0\\\", \\\"1\\\"),\\n    ],\\n)\\ndef test_flag_value_default_is_not_activation(\\n    runner, default, flag_value, type, expected_default, expected_flag\\n):\\n    @click.command()