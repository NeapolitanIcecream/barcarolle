+
+
+def test_shared_flag_default_order_independent(runner):
+    @click.command()
+    @click.option("--first", "value", flag_value=1, default=UNSET)
+    @click.option("--second", "value", flag_value=2, default=2)
+    def first(value):
+        click.echo(value)
+
+    @click.command()
+    @click.option("--second", "value", flag_value=2, default=2)
+    @click.option("--first", "value", flag_value=1, default=UNSET)
+    def second(value):
+        click.echo(value)
+
+    @click.command()
+    @click.pass_context
+    def cli(ctx):
+        ctx.invoke(first)
+        ctx.invoke(second)
+
+    result = runner.invoke(cli, [])
+    assert not result.exception
+    assert result.output.splitlines() == ["2", "2"]
