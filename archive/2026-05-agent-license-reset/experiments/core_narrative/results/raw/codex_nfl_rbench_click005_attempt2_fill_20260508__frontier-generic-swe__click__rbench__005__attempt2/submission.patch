+def test_case_insensitive_choice(runner):
+    @click.command()
+    @click.option('--hash-type', type=click.Choice(['md5', 'sha1'],
+                  case_sensitive=False))
+    def cmd(hash_type):
+        click.echo(hash_type)
+
+    result = runner.invoke(cmd, ['--hash-type', 'MD5'])
+    assert result.exit_code == 0
+    assert result.output == 'md5\n'
+
+    result = runner.invoke(cmd, ['--hash-type', 'SHA1'])
+    assert result.exit_code == 0
+    assert result.output == 'sha1\n'
+
+
