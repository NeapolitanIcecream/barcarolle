+def test_separate_stdout_stderr():
+    @click.command()
+    def test():
+        click.echo('out')
+        click.echo('err', err=True)
+        click.echo('out again')
+
+    runner = CliRunner()
+    result = runner.invoke(test)
+    assert not result.exception
+    assert result.output == 'out\nerr\nout again\n'
+    assert result.stdout == 'out\nout again\n'
+    assert result.stderr == 'err\n'
+    assert result.stdout_bytes == b'out\nout again\n'
+    assert result.stderr_bytes == b'err\n'
+
+
