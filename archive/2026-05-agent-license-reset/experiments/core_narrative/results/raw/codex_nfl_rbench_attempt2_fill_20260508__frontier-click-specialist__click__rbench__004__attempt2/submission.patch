+class _StreamCapture(object):
+
+    def __init__(self, stream, stdout, stderr):
+        self._stream = stream
+        self.stdout_bytes = stdout
+        self.stderr_bytes = stderr
+
+    def __getattr__(self, name):
+        return getattr(self._stream, name)
+
+    def getvalue(self):
+        return self._stream.getvalue()
+
+
+class _TeeStream(object):
+
+    def __init__(self, stream, mixed):
+        self._stream = stream
+        self._mixed = mixed
+
+    def __getattr__(self, name):
+        return getattr(self._stream, name)
+
+    def write(self, value):
+        rv = self._stream.write(value)
+        self._mixed.write(value)
+        return rv
+
+    def flush(self):
+        flush = getattr(self._stream, 'flush', None)
+        if flush is not None:
+            flush()
+        flush = getattr(self._mixed, 'flush', None)
+        if flush is not None:
+            flush()
+
+
+if not PY2:
+    class _TeeBytesIO(io.BytesIO):
+
+        def __init__(self, mixed):
+            io.BytesIO.__init__(self)
+            self._mixed = mixed
+
+        def write(self, value):
+            rv = io.BytesIO.write(self, value)
+            self._mixed.write(value)
+            return rv
+
+
+    def _make_text_stream(stream, charset):
+        try:
+            return io.TextIOWrapper(stream, encoding=charset,
+                                    write_through=True)
+        except TypeError:
+            return io.TextIOWrapper(stream, encoding=charset)
+
