@@ -61,6 +61,25 @@ def test_runner_with_stream():
     assert result.output == 'Hello World!\nHello World!\n'
 
 
+def test_runner_separated_streams():
+    @click.command()
+    def test():
+        click.echo('stdout 1')
+        click.echo('stderr 1', err=True)
+        click.echo('stdout 2')
+        click.echo('stderr 2', err=True)
+
+    runner = CliRunner()
+    result = runner.invoke(test)
+
+    assert not result.exception
+    assert result.output == 'stdout 1\nstderr 1\nstdout 2\nstderr 2\n'
+    assert result.stdout == 'stdout 1\nstdout 2\n'
+    assert result.stderr == 'stderr 1\nstderr 2\n'
+    assert result.stdout_bytes == b'stdout 1\nstdout 2\n'
+    assert result.stderr_bytes == b'stderr 1\nstderr 2\n'
+
+
