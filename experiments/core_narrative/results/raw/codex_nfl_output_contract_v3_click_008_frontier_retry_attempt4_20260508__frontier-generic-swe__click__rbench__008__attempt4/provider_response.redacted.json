      self.prompt = prompt_text\\n        self.prompt_required = prompt_required\\n        self.confirmation_prompt = confirmation_prompt\\n\"},{\"path\":\"src/click/core.py\",\"old\":\"    def consume_value(self, ctx, opts):\\n        value, source = super().consume_value(ctx, opts)\\n\\n        if (\\n            self.prompt is not None\\n            and value is None\\n            and source in {ParameterSource.DEFAULT, ParameterSource.DEFAULT_MAP}\\n        ):\\n            value = self.prompt_for_value(ctx)\\n            source = ParameterSource.PROMPT\\n\\n        return value, source\\n\",\"new\":\"    def consume_value(self, ctx, opts):\\n        value, source = super().consume_value(ctx, opts)\\n\\n        if value is _flag_needs_value:\\n            value = self.prompt_for_value(ctx)\\n            source = ParameterSource.PROMPT\\n        elif (\\n            self.prompt is not None\\n            and value is None\\n            and source in {ParameterSource.DEFAULT, ParameterSource.DEFAULT_MAP}\\n        ):\\n            if not (\\n                ctx.resilient_parsing\\n                or (self.prompt_required is False and not self.required)\\n            ):\\n                value = self.prompt_for_value(ctx)\\n                source = ParameterSource.PROMPT\\n\\n        return value, source\\n\"},{\"path\":\"tests/test_options.py\",\"old\":\"def test_missing_choice(runner):\\n    @click.command()\\n    @click.option(\\\"--foo\\\", type=click.Choice([\\\"foo\\\", \\\"bar\\\"]), required=True)\\n    def cmd(foo):\\n        click.echo(foo)\\n\\n    result = runner.invoke(cmd)\\n    assert result.exit_code == 2\\n    error, separator, choices = result.output.partition(\\\"Choose from\\\")\\n    assert \\\"Error: Missing option '--foo'. \\\" in error\\n    assert \\\"Choose from\\\" in separator\\n    assert \\\"foo\\\" in choices\\n    assert \\\"bar\\\" in choices\\n\\n\\ndef test_case_insensitive_choice(runner):\\n\",\"new\":\"def test_missing_choice(runner):\\n    @click.command()\\n    @click.option(\\\"--foo\\\", type=click.Choice([\\\"foo\\\", \\\"bar\\\"]), required=True)\\n    def cmd(foo):\\n        click.echo(foo)\\n\\n    result = runner.invoke(cmd)\\n    assert result.exit_code == 2\\n    error, separator, choices = result.output.partition(\\\"Choose from\\\")\\n    assert \\\"Error: Missing option '--foo'. \\\" in error\\n    assert \\\"Choose from\\\" in separator\\n    assert \\\"foo\\\" in choices\\n    assert \\\"bar\\\" in choices\\n\\n\\ndef test_prompt_required_false(runner):\\n    @click.command()\\n    @click.option(\\\"--name\\\", prompt=True, prompt_required=False, default=\\\"Default\\\")\\n    def cmd(name):\\n        click.echo(name)\\n\\n    result = runner.invoke(cmd)\\n    assert result.output == \\\"Default\\\\n\\\"\\n\\n    result = runner.invoke(cmd, [\\\"--name\\\"], input=\\\"Flag\\\\n\\\")\\n    assert result.output == \\\"Name [Default]: Flag\\\\nFlag\\\\n\\\"\\n\\n\\ndef test_prompt_required_false_required(runner):\\n    @click.command()\\n    @click.option(\\\"--name\\\", prompt=True, prompt_required=False, required=True)\\n    def cmd(name):\\n        click.echo(name)\\n\\n    result = runner.invoke(cmd, input=\\\"Prompt\\\\n\\\")\\n    assert result.output == \\\"Name: Prompt\\\\nPrompt\\\\n\\\"\\n\\n\\ndef test_prompt_missing_value_before_option(runner):\\n    @click.command()\\n    @click.option(\\\"--name\\\", prompt=True)\\n    @click.option(\\\"--flag\\\", is_flag=True)\\n    def cmd(name, flag):\\n        click.echo(f\\\"{name}:{flag}\\\")\\n\\n    result = runner.invoke(cmd, [\\\"--name\\\", \\\"--flag\\\"], input=\\\"Prompt\\\\n\\\")\\n    assert result.output == \\\"Name: Prompt\\\\nPrompt:True\\\\n\\\"\\n\\n\\ndef test_case_insensitive_choice(runner):\\n\"}]}","refusal":null,"reasoning":"**Evaluating command options**\n\nI think `--opt --other` shouldn't have a value because it might cause issues if the value starts with a dash. Maybe there are existing tests that co