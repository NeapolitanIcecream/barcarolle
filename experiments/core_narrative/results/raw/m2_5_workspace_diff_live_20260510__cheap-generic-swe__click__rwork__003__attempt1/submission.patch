diff --git a/src/click/core.py b/src/click/core.py
index cd8052f..6aef8ff 100644
--- a/src/click/core.py
+++ b/src/click/core.py
@@ -1228,0 +1229,4 @@ class Command:
+        for name, value in ctx.params.items():
+            if value is UNSET:
+                ctx.params[name] = None
+
@@ -2536,7 +2540,6 @@ class Parameter:
-        if (
-            self.expose_value
-            # We skip adding the value if it was previously set by another parameter
-            # targeting the same variable name. This prevents parameters competing for
-            # the same name to override each other.
-            and self.name not in ctx.params
-        ):
+        if self.expose_value:
+            # Preserve the first real value for a shared parameter name, but allow a
+            # later non-UNSET value to replace an internal UNSET placeholder.
+            current_value = ctx.params.get(self.name, UNSET)
+            if current_value is not UNSET:
+                return value, args
@@ -2548,4 +2551 @@ class Parameter:
-            # Normalize UNSET values to None, as we're about to pass them to the
-            # command function and move them to the pure-Python realm of user-written
-            # code.
-            ctx.params[self.name] = value if value is not UNSET else None
+            ctx.params[self.name] = value
diff --git a/tests/test_defaults.py b/tests/test_defaults.py
index 3f293e8..4c52a8f 100644
--- a/tests/test_defaults.py
+++ b/tests/test_defaults.py
@@ -1,0 +2 @@ import click
+import pytest
@@ -86,0 +88,20 @@ def test_flag_default_map(runner):
+
+
+@pytest.mark.parametrize(
+    "declaration_order",
+    [
+        ("flag-first", ("--flag", "--value")),
+        ("value-first", ("--value", "--flag")),
+    ],
+)
+def test_shared_parameter_default_order(runner, declaration_order):
+    _, options = declaration_order
+
+    @click.command()
+    @click.option(options[0], "value", flag_value="flag")
+    @click.option(options[1], "value", default="default")
+    def cli(value):
+        click.echo(value)
+
+    result = runner.invoke(cli, [])
+    assert result.output == "default\n"
