+
+
+@pytest.mark.parametrize("shared_flag_first", [True, False])
+def test_shared_flag_default_regression(runner, shared_flag_first):
+    if shared_flag_first:
+
+        @click.command()
+        @click.option("--upper", "value", flag_value="upper")
+        @click.option("--value", default="lower")
+        def cli(value):
+            click.echo(value)
+
+    else:
+
+        @click.command()
+        @click.option("--value", default="lower")
+        @click.option("--upper", "value", flag_value="upper")
+        def cli(value):
+            click.echo(value)
+
+    result = runner.invoke(cli, [])
+    assert not result.exception
+    assert result.output.strip() == "lower"
+
+    result = runner.invoke(cli, ["--upper"])
+    assert not result.exception
+    assert result.output.strip() == "upper"
