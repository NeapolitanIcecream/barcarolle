+def test_pdb_uses_real_streams():
+    real_stdin = sys.stdin
+    real_stdout = sys.stdout
+    explicit_stdin = StringIO()
+    explicit_stdout = StringIO()
+    old_pdb_init = pdb.Pdb.__init__
+
+    @click.command()
+    def cli_pdb():
+        default_debugger = pdb.Pdb()
+        assert default_debugger.stdin is real_stdin
+        assert default_debugger.stdout is real_stdout
+
+        explicit_debugger = pdb.Pdb(stdin=explicit_stdin, stdout=explicit_stdout)
+        assert explicit_debugger.stdin is explicit_stdin
+        assert explicit_debugger.stdout is explicit_stdout
+
+    runner = CliRunner()
+    result = runner.invoke(cli_pdb)
+
+    assert result.exception is None
+    assert pdb.Pdb.__init__ is old_pdb_init
+
