{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barcarolle.local/experiments/core_narrative/schemas/acut.schema.json",
  "title": "Core Narrative ACUT Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "acut_id",
    "provider",
    "model",
    "prompt_policy_digest",
    "frozen_at",
    "operator"
  ],
  "$defs": {
    "freeform_object": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "properties": {
    "schema_version": {
      "const": "core-narrative.acut.v1"
    },
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "acut_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string"
    },
    "frozen": {
      "type": "boolean"
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "description": "Top-level model/provider family, for example openai."
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "Top-level model identifier, for example gpt-5.5."
    },
    "model_parameters": {
      "$ref": "#/$defs/freeform_object"
    },
    "prompt_policy_digest": {
      "type": "string",
      "minLength": 1
    },
    "prompt_policy_reference": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool_permissions": {
      "$ref": "#/$defs/freeform_object"
    },
    "retrieval_context_strategy": {
      "$ref": "#/$defs/freeform_object"
    },
    "runtime_budget": {
      "$ref": "#/$defs/freeform_object"
    },
    "network_policy": {
      "$ref": "#/$defs/freeform_object"
    },
    "execution_mode": {
      "$ref": "#/$defs/freeform_object"
    },
    "adapter_or_harness_basis": {
      "$ref": "#/$defs/freeform_object"
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time"
    },
    "operator": {
      "type": "string",
      "minLength": 1
    },
    "score_fields": {
      "$ref": "#/$defs/freeform_object"
    },
    "notes": {
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/freeform_object"
    }
  }
}
